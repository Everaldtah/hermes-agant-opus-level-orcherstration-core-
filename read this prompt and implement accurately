# Event bus (pub/sub for decoupled component communication)
self.events = get_event_bus()

# LLM Provider Manager with failover chain
self.provider_manager = ProviderManager()
# AUTO mode reads env vars: GLM_API_KEY, OPENROUTER_API_KEY, KIMI_API_KEY, ANTHROPIC_API_KEY
# Failover order: GLM → Kimi K2.5 (OpenRouter) → Kimi (direct) → Claude → LM Studio → Mock

# Long-term memory (3-tier: episodic → semantic → procedural)
self.memory_store = MemoryStore(db_path="~/.hermes/memory.db")

# Swarm orchestrator (sub-agent delegation)
self.swarm = SwarmOrchestrator(
    provider_manager=self.provider_manager,
    event_bus=self.events,
    memory_store=self.memory_store,
)

# Task orchestrator (multi-step task decomposition)
self.orchestrator = TaskOrchestrator(
    provider_manager=self.provider_manager,
    event_bus=self.events,
    max_context_tokens=self.config.max_context,
)
```

